{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "ReadFile": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "base_url": {
                    "type": "string"
                },
                "resources": {
                    "$ref": "#/defs/BpaFileList"
                }
            }
        },
        "BpaFileList": {
            "type": "object",
            "properties": {
                "r1": {
                    "$ref": "#/defs/BpaFile"
                },
                "r2": {
                    "$ref": "#/defs/BpaFile"
                },
                "single_end": {
                    "$ref": "#/defs/BpaFile"
                }
            }
        },
        "BpaFile": {
            "type": "object",
            "properties": {
                "url": {
                    "type": "string"
                },
                "md5sum": {
                    "type": "string"
                },
                "lane_number": {
                    "type": "string"
                }
            }
        }
    },
    "type": "object",
    "required": [
        "assembly_version",
        "busco_odb10_dataset_name",
        "busco_odb12_dataset_name",
        "dataset_id",
        "reads",
        "scientific_name",
        "taxon_id"
    ],
    "properties": {
        "assembly_version": {
            "type": "integer",
            "description": "AToL assembly version for this ToLID"
        },
        "busco_odb10_dataset_name": {
            "type": "string",
            "description": "Required for ASCC"
        },
        "busco_odb12_dataset_name": {
            "type": "string",
            "description": "Required for genomeassembly"
        },
        "dataset_id": {
            "type": "string",
            "description": "Usually a ToLID"
        },
        "find_plastid": {
            "type": "boolean",
            "description": "If true will run mitohifi plastid finding during genomeassembly"
        },
        "hic_motif": {
            "type": "string",
            "description": "Usually GATC,GANTC,CTNAG,TTAA for Arima"
        },
        "mitochondrial_genetic_code_id": {
            "type": "integer",
            "description": "Required to run MitoHifi in genomeassembly"
        },
        "mitohifi_reference_species": {
            "type": "string",
            "description": "Required to run MitoHifi in genomeassembly"
        },
        "ncbi_class": {
            "type": "string",
            "description": "Required for TreeVal"
        },
        "oatk_hmm_name": {
            "type": "string",
            "description": "Required to run OatK in genomeassembly"
        },
        "scientific_name": {
            "type": "string",
            "description": "Binomial name, e.g. Vombatus ursinus"
        },
        "taxon_id": {
            "type": "integer",
            "description": "Must be a valid NCBI TaxId"
        },
        "reads": {
            "type": "array",
            "minItems": 1,
            "properties": {
                "PACBIO_SMRT": {
                    "type": "object"
                },
                "Hi-C": {
                    "type": "object"
                },
                "OXFORD_NANOPORE": {
                    "type": "object"
                }
            }
        }
    }
}