{
    "config": "config",
    "downloads": "resources/raw_reads/{data_type}",
    "logs": "logs/{stage}",
    "pipeline_output": "results/{pipeline}/{dataset_id}.{assembly_version}",
    "profiles": "profiles",
    "qc_reads": "results/qc/reads/{data_type}",
    "qc_stats": "results/qc/stats/{data_type}",
    "qc": "results/qc",
    "resources": "resources",
    "results": "results",
    "scripts": "scripts",
    "stages": {
        "raw": {
            "dir": "downloads",
            "logs": "logs/download",
            "outputs": {
                "paired_end": {
                    "r1": "{name}.r1.{ext}",
                    "r2": "{name}.r2.{ext}"
                },
                "single_end": {
                    "reads": "{name}.{ext}"
                }
            }
        },
        "qc": {
            "dir": "qc_reads",
            "logs": "logs/qc",
            "outputs": {
                "paired_end": {
                    "reads": "{name}.{ext}"
                },
                "single_end": {
                    "reads": "{name}.{ext}"
                }
            },
            "ext": {
                "Hi-C": "cram",
                "OXFORD_NANOPORE": "fastq.gz",
                "PACBIO_SMRT": "fastq.gz"
            },
            "stats": {
                "dir": "qc_stats",
                "pattern": "{name}.json"
            }
        },
        "genomeassembly": {
            "dir": "pipeline_output",
            "logs": "logs/genomeassembly",
            "pipeline_input": {
                "genomic_data": "config/genomeassembly.data.yaml",
                "assembly_specs": "config/genomeassembly.spec.yaml"
            },
            "pipeline_runscript": "scripts/genomeassembly.sh",
            "upload": {
                "exclude_patterns": [
                    "*.bam",
                    "*.bin",
                    "*.ktab.*"
                ],
                "compress_extensions": [
                    ".bed",
                    ".paf"
                ]
            }
        },
        "ascc": {
            "dir": "pipeline_output",
            "logs": "logs/ascc",
            "pipeline_input": "config/ascc.yaml",
            "pipeline_runscript": "scripts/ascc.sh",
            "upload": {
                "exclude_patterns": [],
                "compress_extensions": [
                    ".fasta"
                ]
            }
        },
        "curationpretext": {
            "dir": "pipeline_output",
            "logs": "logs/curationpretext",
            "pipeline_input": "config/curationpretext.yaml",
            "pipeline_runscript": "scripts/curationpretext.sh",
            "upload": {
                "exclude_patterns": [],
                "compress_extensions": []
            }
        },
        "treeval": {
            "dir": "pipeline_output",
            "logs": "logs/treeval",
            "pipeline_input": "config/treeval.yaml",
            "pipeline_runscript": "scripts/treeval.sh",
            "upload": {
                "exclude_patterns": [
                    "*.ktab.*"
                ],
                "compress_extensions": [
                    ".bed"
                ]
            }
        }
    }
}