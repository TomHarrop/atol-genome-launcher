{
    "pacbio_hifi.purged": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": false,
        "assembler": "hifiasm",
        "outputs": {
            "genomeassembly": {
                "PRIMARY": "{dataset_id}.{assembly_version}.pacbio_hifi.purged/purging/asm.purged.fa.gz",
                "HAPLO": "{dataset_id}.{assembly_version}.pacbio_hifi.purged/purging/asm.htigs.all.fa.gz"
            },
            "ascc": {
                "PRIMARY": "{dataset_id}.{assembly_version}_PRIMARY/autofilter/{dataset_id}.{assembly_version}_PRIMARY_autofiltered.fasta",
                "HAPLO": "{dataset_id}.{assembly_version}_HAPLO/autofilter/{dataset_id}.{assembly_version}_HAPLO_autofiltered.fasta"
            }
        }
    },
    "oxford_nanopore.purged": {
        "long_read_platform": "oxford_nanopore",
        "requires_hic": false,
        "assembler": "hifiasm",
        "outputs": {
            "genomeassembly": {
                "PRIMARY": "{dataset_id}.{assembly_version}.oxford_nanopore.purged/purging/asm.purged.fa.gz",
                "HAPLO": "{dataset_id}.{assembly_version}.oxford_nanopore.purged/purging/asm.htigs.all.fa.gz"
            },
            "ascc": {
                "PRIMARY": "{dataset_id}.{assembly_version}_PRIMARY/autofilter/{dataset_id}.{assembly_version}_PRIMARY_autofiltered.fasta",
                "HAPLO": "{dataset_id}.{assembly_version}_HAPLO/autofilter/{dataset_id}.{assembly_version}_HAPLO_autofiltered.fasta"
            }
        }
    },
    "pacbio_hifi.phased": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": true,
        "assembler": "hifiasm",
        "outputs": {
            "genomeassembly": {
                "PRIMARY": "{dataset_id}.{assembly_version}.pacbio_hifi.phased/scaffolding/asm_hap1_scaffolds_final.fa.gz",
                "HAPLO": "{dataset_id}.{assembly_version}.pacbio_hifi.phased/scaffolding/asm_hap2_scaffolds_final.fa.gz"
            },
            "ascc": {
                "PRIMARY": "{dataset_id}.{assembly_version}_PRIMARY/autofilter/{dataset_id}.{assembly_version}_PRIMARY_autofiltered.fasta",
                "HAPLO": "{dataset_id}.{assembly_version}_HAPLO/autofilter/{dataset_id}.{assembly_version}_HAPLO_autofiltered.fasta"
            }
        }
    },
    "oxford_nanopore.phased": {
        "long_read_platform": "oxford_nanopore",
        "requires_hic": true,
        "assembler": "hifiasm",
        "outputs": {
            "genomeassembly": {
                "PRIMARY": "{dataset_id}.{assembly_version}.oxford_nanopore.phased/scaffolding/asm_hap1_scaffolds_final.fa.gz",
                "HAPLO": "{dataset_id}.{assembly_version}.oxford_nanopore.phased/scaffolding/asm_hap2_scaffolds_final.fa.gz"
            },
            "ascc": {
                "PRIMARY": "{dataset_id}.{assembly_version}_PRIMARY/autofilter/{dataset_id}.{assembly_version}_PRIMARY_autofiltered.fasta",
                "HAPLO": "{dataset_id}.{assembly_version}_HAPLO/autofilter/{dataset_id}.{assembly_version}_HAPLO_autofiltered.fasta"
            }
        }
    },
    "oatk": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": false,
        "requires_hmm": true,
        "assembler": "oatk",
        "outputs": {
            "genomeassembly": {
                "MITO": "{dataset_id}.{assembly_version}.oatk/asm.k1000_c320.mito.ctg.fasta",
                "PLASTID": "{dataset_id}.{assembly_version}.oatk/asm.k1000_c320.pltd.ctg.fasta"
            }
        }
    },
    "mitohifi": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": false,
        "requires_mitohifi_reference_species": true,
        "assembler": "mitohifi",
        "outputs": {
            "genomeassembly": {
                "MITO": "{dataset_id}.{assembly_version}.mitohifi/FIXME.fa",
                "PLASTID": "{dataset_id}.{assembly_version}.mitohifi/FIXME.fa"
            }
        }
    }
}