{
    "pacbio_hifi.purged": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": false,
        "assembler": "hifiasm",
        "outputs": {
            "PRIMARY": "{dataset_id}.{assembly_version}/{dataset_id}.pacbio_hifi.purged/purging/asm.purged.fa.gz",
            "HAPLO": "{dataset_id}.{assembly_version}/{dataset_id}.pacbio_hifi.purged/purging/asm.htigs.all.fa.gz"
        }
    },
    "oxford_nanopore.purged": {
        "long_read_platform": "oxford_nanopore",
        "requires_hic": false,
        "assembler": "hifiasm",
        "outputs": {
            "PRIMARY": "{dataset_id}.{assembly_version}/{dataset_id}.oxford_nanopore.purged/purging/asm.purged.fa.gz",
            "HAPLO": "{dataset_id}.{assembly_version}/{dataset_id}.oxford_nanopore.purged/purging/asm.htigs.all.fa.gz"
        }
    },
    "pacbio_hifi.phased": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": true,
        "assembler": "hifiasm",
        "outputs": {
            "PRIMARY": "{dataset_id}.{assembly_version}/{dataset_id}.pacbio_hifi.phased/scaffolding/asm_hap1_scaffolds_final.fa.gz",
            "HAPLO": "{dataset_id}.{assembly_version}/{dataset_id}.pacbio_hifi.phased/scaffolding/asm_hap2_scaffolds_final.fa.gz"
        }
    },
    "oxford_nanopore.phased": {
        "long_read_platform": "oxford_nanopore",
        "requires_hic": true,
        "assembler": "hifiasm",
        "outputs": {
            "PRIMARY": "{dataset_id}.{assembly_version}/{dataset_id}.oxford_nanopore.phased/scaffolding/asm_hap1_scaffolds_final.fa.gz",
            "HAPLO": "{dataset_id}.{assembly_version}/{dataset_id}.oxford_nanopore.phased/scaffolding/asm_hap2_scaffolds_final.fa.gz"
        }
    },
    "oatk": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": false,
        "requires_hmm": true,
        "assembler": "oatk",
        "outputs": {
            "MITO": "{dataset_id}.{assembly_version}/{dataset_id}.oatk.mito.fa.gz",
            "PLASTID": "{dataset_id}.{assembly_version}/{dataset_id}.oatk.plastid.fa.gz"
        }
    },
    "mitohifi": {
        "long_read_platform": "pacbio_hifi",
        "requires_hic": false,
        "requires_mitohifi_reference_species": true,
        "assembler": "mitohifi",
        "outputs": {
            "MITO": "{dataset_id}.{assembly_version}/{dataset_id}.mitohifi.mito.fa.gz",
            "PLASTID": "{dataset_id}.{assembly_version}/{dataset_id}.mitohifi.plastid.fa.gz"
        }
    }
}