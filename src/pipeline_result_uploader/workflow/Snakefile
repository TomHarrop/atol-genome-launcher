from pathlib import Path
from yaml_manifest.layout import collect_upload_files
from yaml_manifest.parser import load_manifest
import tempfile


tempdir = tempfile.mkdtemp()
globals().update(config)

# Load the manifest and classify files
manifest = load_manifest(Path(manifest))
output_dir = manifest.get_dir("pipeline_output", pipeline=stage)
classified = collect_upload_files(stage, output_dir)

upload_files = classified["upload"]
compress_files_list = classified["compress"]

# Build the list of all files to upload with their remote paths.
# The remote path mirrors the local path.
all_uploads = {}
for f in upload_files:
    all_uploads[str(f)] = str(f)

compress_targets = {}
for f in compress_files_list:
    gz = f.with_name(f.name + ".gz")
    compress_targets[str(f)] = {
        "gz": str(gz),
        "remote": str(gz),
    }


rule compress_file:
    input:
        original="{filepath}",
    output:
        gz="{filepath}.gz",
    shell:
        "gzip --keep --force {input.original}"


rule upload_file:
    input:
        local_file="{filepath}",
    output:
        receipt=Path(tempdir, "{filepath}.receipt.jsonl"),
    params:
        remote=lambda wc: (
            all_uploads.get(wc.filepath)
            or compress_targets[wc.filepath.removesuffix(".gz")]["remote"]
        ),
        bucket=bucket,
    shell:
        "result-file-uploader "
        "{input.local_file} "
        "{params.remote} "
        "--bucket {params.bucket} "
        "> {output.receipt}"


# raise ValueError()
# raise ValueError(
#     expand(rules.upload_file.output, filepath=compress_targets.values()),
# )

upload_receipts = sorted(set(expand(rules.upload_file.output, filepath=all_uploads)))
compressed_file_upload_receipts = sorted(
    set(
        expand(
            rules.upload_file.output,
            filepath=[x.get("gz", None) for x in compress_targets.values()],
        )
    )
)


rule target:
    default_target: True
    input:
        upload_receipts,
        compressed_file_upload_receipts,


onsuccess:
    output_jsonl = Path(tempdir, "upload_manifest.jsonl")
    all_receipts = sorted(set(upload_receipts + compressed_file_upload_receipts))
    with open(output_jsonl, "w") as out:
        for receipt_path in all_receipts:
            with open(receipt_path, "rt") as f:
                line = f.read().strip()
            if line:
                out.write(line + "\n")
    print(f"Upload manifest written to {output_jsonl}")
